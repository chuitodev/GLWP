BRIDE_PARENTS_TITLE=Padres de la novia
BRIDE_PARENTS_NAMES=Elena|Fernando
STORY_PHOTO_1=/uploads/story-1.jpg
STORY_PHOTO_1_ALT=Foto 1 de la galeria
