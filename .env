# ========================================
# GLWP INVITATION CONFIG
# ========================================
# Instrucciones:
# 1) Sube tus fotos a la carpeta local ./uploads
# 2) Usa rutas que empiecen con /uploads/
#    Ejemplo: /uploads/hero.jpg
# 3) Para controlar el orden de las fotos de la galeria usa:
#    STORY_PHOTO_1, STORY_PHOTO_2, STORY_PHOTO_3
#    Se renderizan de izquierda a derecha en ese orden.
# 4) Para agregar o quitar elementos repetibles cambia el COUNT
#    correspondiente y luego completa cada bloque numerado.
# 5) Este archivo ahora funciona como semilla inicial y configuracion tecnica.
#    El contenido editable de la invitacion se administra desde /admin.
#
# Nota:
# - El RSVP se guarda automaticamente en ./data/rsvp-submissions.txt
#   y tambien en ./data/rsvp-submissions.ndjson

PORT=8080
BRAND_LABEL=GLWP INVITATION SYSTEM
TOPBAR_ACTION_LABEL=Ir a RSVP
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ========================================
# PALETA GLOBAL DE LA INVITACION
# Guia rapida:
# - THEME_COLOR_BACKGROUND: fondo base de toda la pagina
# - THEME_COLOR_BACKGROUND_STRONG: fondos suaves auxiliares
# - THEME_COLOR_BACKGROUND_END: remate del degradado del fondo
# - THEME_COLOR_SURFACE: fondo de tarjetas y secciones
# - THEME_COLOR_SURFACE_STRONG: fondo de tarjetas destacadas
# - THEME_COLOR_BORDER: bordes y lineas divisoras
# - THEME_COLOR_TEXT: texto general
# - THEME_COLOR_TEXT_MUTED: subtitulos y texto secundario
# - THEME_COLOR_TITLE: titulos grandes
# - THEME_COLOR_PRIMARY: botones principales, links destacados, acentos
# - THEME_COLOR_PRIMARY_SOFT: fondos suaves del color principal
# - THEME_COLOR_PRIMARY_TEXT: texto dentro de botones principales
# - THEME_COLOR_HERO_TEXT: texto dentro del hero principal
# - THEME_COLOR_SUCCESS: confirmaciones exitosas
# - THEME_HERO_GRADIENT_START/MID/END: degradado del bloque principal
# Referencia actual (defaults):
# - Fondo base: #fbf5ef
# - Fondo fuerte: #f1e4d6
# - Fondo degradado final: #efe1d2
# - Tarjetas: rgba(255, 252, 247, 0.74)
# - Tarjetas fuertes: rgba(255, 249, 242, 0.92)
# - Bordes: rgba(92, 64, 51, 0.14)
# - Texto principal: #34231c
# - Texto secundario: #70554a
# - Titulos: #34231c
# - Primario: #b4664a
# - Primario suave: rgba(180, 102, 74, 0.12)
# - Texto sobre primario: #fff9f4
# - Texto del hero: #fff8f1
# - Exito: #2d6b4b
# ========================================
THEME_COLOR_BACKGROUND=#fbf5ef
THEME_COLOR_BACKGROUND_STRONG=#f1e4d6
THEME_COLOR_BACKGROUND_END=#efe1d2
THEME_COLOR_SURFACE=rgba(255, 252, 247, 0.74)
THEME_COLOR_SURFACE_STRONG=rgba(255, 249, 242, 0.92)
THEME_COLOR_BORDER=rgba(92, 64, 51, 0.14)
THEME_COLOR_TEXT=#34231c
THEME_COLOR_TEXT_MUTED=#70554a
THEME_COLOR_TITLE=#34231c
THEME_COLOR_PRIMARY=#b4664a
THEME_COLOR_PRIMARY_SOFT=rgba(180, 102, 74, 0.12)
THEME_COLOR_PRIMARY_TEXT=#fff9f4
THEME_COLOR_HERO_TEXT=#fff8f1
THEME_COLOR_SUCCESS=#2d6b4b
THEME_HERO_GRADIENT_START=#4d352c
THEME_HERO_GRADIENT_MID=#a66f57
THEME_HERO_GRADIENT_END=#f3e3d2

# ========================================
# PAREJA Y HERO
# ========================================
BRIDE_NAME=Camila
GROOM_NAME=Julian
COUPLE_DISPLAY_NAME=
HERO_EYEBROW=Nos casamos
HERO_SUBTITLE=Una celebracion para bailar, abrazar y volver a enamorarnos de la vida juntos.
HERO_PHOTO=/uploads/hero.jpg
