# ========================================
# GLWP INVITATION CONFIG
# ========================================
# Instrucciones:
# 1) Sube tus fotos a la carpeta local ./uploads
# 2) Usa rutas que empiecen con /uploads/
#    Ejemplo: /uploads/hero.jpg
# 3) Para controlar el orden de las fotos de la galeria usa:
#    STORY_PHOTO_1, STORY_PHOTO_2, STORY_PHOTO_3
#    Se renderizan de izquierda a derecha en ese orden.
# 4) Para agregar o quitar elementos repetibles cambia el COUNT
#    correspondiente y luego completa cada bloque numerado.
# 5) Si cambias este archivo y usas Docker, reinicia el contenedor:
#    docker compose up --build -d
#
# Nota:
# - El RSVP se guarda automaticamente en ./data/rsvp-submissions.txt
#   y tambien en ./data/rsvp-submissions.ndjson

PORT=8080
BRAND_LABEL=GLWP INVITATION SYSTEM
TOPBAR_ACTION_LABEL=Ir a RSVP

# ========================================
# PAREJA Y HERO
# ========================================
BRIDE_NAME=Camila
GROOM_NAME=Julian
COUPLE_DISPLAY_NAME=
HERO_EYEBROW=Nos casamos
HERO_SUBTITLE=Una celebracion para bailar, abrazar y volver a enamorarnos de la vida juntos.
HERO_PHOTO=/uploads/hero.jpg
HERO_PHOTO_ALT=Foto principal de los novios
EVENT_DATE=2026-11-21T17:00:00-06:00
EVENT_TIMEZONE=America/Mexico_City
EVENT_CITY=San Miguel de Allende, Guanajuato

# ========================================
# PADRES Y GALERIA
# ========================================
PARENTS_SECTION_TITLE=Nuestros padres
PARENTS_SECTION_TEXT=
