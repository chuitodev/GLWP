GROOM_PARENTS_NAMES=Martha y Roberto
BRIDE_PARENTS_TITLE=Padres de la novia
BRIDE_PARENTS_NAMES=Elena y Fernando
STORY_PHOTO_1=/uploads/story-1.jpg
STORY_PHOTO_1_ALT=Foto 1 de la galeria
STORY_PHOTO_2=/uploads/story-2.jpg
STORY_PHOTO_2_ALT=Foto 2 de la galeria
STORY_PHOTO_3=/uploads/story-3.jpg
STORY_PHOTO_3_ALT=Foto 3 de la galeria

# ========================================
# ITINERARIO
# El orden aqui define:
# - El orden en la seccion Itinerario
# - Las 3 tarjetas del hero despues de la fecha
# Sugerencia:
# 1 = Ceremonia religiosa
# 2 = Ceremonia civil
# 3 = Recepcion / evento
# ========================================
TIMELINE_TITLE=Itinerario
TIMELINE_DESCRIPTION=Cada bloque del evento se configura desde el archivo .env y se renderiza en el orden indicado.
TIMELINE_COUNT=3

TIMELINE_1_LABEL=Ceremonia religiosa
TIMELINE_1_TIME=16:00
TIMELINE_1_VENUE=Parroquia de San Miguel Arcangel
TIMELINE_1_ADDRESS=Centro Historico, San Miguel de Allende
TIMELINE_1_MAPS_URL=https://maps.google.com/

TIMELINE_2_LABEL=Ceremonia civil
TIMELINE_2_TIME=17:30
TIMELINE_2_VENUE=Huerto del Angel
TIMELINE_2_ADDRESS=Salida Real a Queretaro 64, San Miguel de Allende
TIMELINE_2_MAPS_URL=https://maps.google.com/

TIMELINE_3_LABEL=Recepcion
TIMELINE_3_TIME=19:30
TIMELINE_3_VENUE=Casa Adela
TIMELINE_3_ADDRESS=Zacateros 12, San Miguel de Allende
TIMELINE_3_MAPS_URL=https://maps.google.com/

