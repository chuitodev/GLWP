# ========================================
# MESA DE REGALOS
# Si ACTION_URL existe, abre enlace.
# Si COPY_VALUE existe, copia ese valor.
# REGISTRY_n_DETAILS permite lineas extra separadas por "|"
# Ejemplo:
# REGISTRY_3_DETAILS=Banco: Banorte|Titular: Camila Perez|CLABE: 0123 4567 8910 1112 131
# REGISTRY_3_COPY_VALUE=0123456789101112131
# Si dejas ambos vacios, solo se muestra informativo.
# ========================================
REGISTRY_TITLE=Mesa de regalos
REGISTRY_DESCRIPTION=Cada item puede ser solo informativo, abrir un enlace o copiar un dato.
REGISTRY_COUNT=3

REGISTRY_1_TITLE=Liverpool
REGISTRY_1_DESCRIPTION=Mesa digital con envios y pagos seguros.
REGISTRY_1_DETAILS=
REGISTRY_1_ACTION_LABEL=Abrir mesa
REGISTRY_1_ACTION_URL=https://example.com/
REGISTRY_1_COPY_VALUE=

REGISTRY_2_TITLE=Lluvia de sobres
REGISTRY_2_DESCRIPTION=Tendremos un espacio para recibir detalles libres.
REGISTRY_2_DETAILS=
REGISTRY_2_ACTION_LABEL=
REGISTRY_2_ACTION_URL=
REGISTRY_2_COPY_VALUE=

REGISTRY_3_TITLE=Transferencia bancaria
REGISTRY_3_DESCRIPTION=Comparte solo el dato exacto que quieras copiar.
REGISTRY_3_DETAILS=CLABE: 0123 4567 8910 1112 131
REGISTRY_3_ACTION_LABEL=Copiar CLABE
REGISTRY_3_ACTION_URL=
REGISTRY_3_COPY_VALUE=0123456789101112131

